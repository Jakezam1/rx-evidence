# Copy this file to `.env` (in the same directory) and fill in real values.
# `.env` is gitignored — never commit it.

# ----------------------------------------------------------------
# LLM provider selection
# ----------------------------------------------------------------
# Which provider to use for analysis. Options: gemini | anthropic | openai
LLM_PROVIDER=gemini

# Optional override for the model id. If unset, uses the provider default
# from app/services/llm/__init__.py (DEFAULT_MODELS).
# LLM_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------
# Provider API keys (only set the one you're using)
# ----------------------------------------------------------------
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ----------------------------------------------------------------
# Pipeline performance
# ----------------------------------------------------------------
# Run section LLM calls concurrently instead of sequentially.
# Sequential (default): safer, predictable load, slower (~3 min/paper on Flash).
# Parallel: ~3-4x faster on healthy providers, but hits rate limits and 503s harder.
# To roll back: set to false or remove the line, then restart uvicorn.
# PARALLEL_SECTIONS=false

# Max concurrent section LLM calls when PARALLEL_SECTIONS=true. Default: 3.
# Lower = fewer 503s under bursty load; higher = faster on healthy providers.
# MAX_PARALLEL_WORKERS=3

# ----------------------------------------------------------------
# Database (defaults to local SQLite if unset)
# ----------------------------------------------------------------
# DATABASE_URL=sqlite:///./rxevidence.db

# ----------------------------------------------------------------
# Demo paper pin
# ----------------------------------------------------------------
# UUID of the bundled PARADIGM-HF (NEJMoa1409077) demo — pre-seeded on deploy when
# AUTO_SEED_DEMO is true (default). Matches api/app/seed/ bundle.
# DEMO_PAPER_ID=e793e16f-5016-47ba-83fb-5d123c896a9c

# ----------------------------------------------------------------
# Demo seed (production / Render)
# ----------------------------------------------------------------
# When true, API startup loads bundled demo_bundle.json + PDF if this paper id is missing.
# Set to false if you do not want the NEJM demo in your database.
# AUTO_SEED_DEMO=true

